{
  "name": "pulsegrid-ai",
  "private": true,
  "version": "1.0.0",
  "description": "PulseGrid AI — Emergency Triage System",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan.bold,green.bold\" \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && python -m uvicorn main:app --reload --port 8000",
    "frontend": "npm --prefix frontend-react run dev",
    "install:all": "npm --prefix frontend-react install",
    "setup": "pip install --prefer-binary -r backend/requirements.txt && npm --prefix frontend-react install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
